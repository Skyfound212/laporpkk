{
  "expo": {
    "name": "PKK Digital",
    "slug": "laporpkk",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "pkk212",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#7ECDC0"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.pkk212.digital",
      "infoPlist": {
        "UIBackgroundModes": [
          "remote-notification"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#7ECDC0"
      },
      "package": "com.pkk212.digital",
      "versionCode": 1,
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.WAKE_LOCK",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/adaptive-icon.png",
          "color": "#7ECDC0",
          "sounds": [
            "./assets/sounds/notification.mp3"
          ]
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Aplikasi memerlukan akses galeri untuk mengunggah foto dokumentasi."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Aplikasi memerlukan akses galeri untuk memilih foto.",
          "savePhotosPermission": "Aplikasi memerlukan akses untuk menyimpan foto.",
          "isAccessMediaLocationEnabled": true
        }
      ],
      [
        "expo-document-picker",
        {
          "iCloudContainerEnvironment": "Production"
        }
      ],
      "expo-font",
      [
        "expo-updates",
        {
          "handleMissingNativeModule": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "d1e40f88-72f7-4d24-bf0f-d6041b48d0ae"
      }
    },
    "owner": "badboy365s-team",
    "jsEngine": "hermes",
    "updates": {
      "url": "https://u.expo.dev/d1e40f88-72f7-4d24-bf0f-d6041b48d0ae",
      "enabled": true,
      "checkAutomatically": "ON_LOAD"
    },
    "runtimeVersion": {
      "policy": "sdkVersion"
    }
  }
}
